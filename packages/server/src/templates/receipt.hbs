<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Receipt {{payment.paymentNumber}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 13px; color: #1a1a1a; background: #fff; }
    .page { width: 794px; min-height: 1123px; margin: 0 auto; padding: 48px 56px; }

    /* Header */
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
    .logo { max-height: 64px; max-width: 200px; }
    .org-name { font-size: 22px; font-weight: 700; color: {{brandPrimary}}; }
    .doc-title { text-align: right; }
    .doc-title h1 { font-size: 32px; font-weight: 700; color: {{brandPrimary}}; letter-spacing: -0.5px; }
    .doc-title .doc-number { font-size: 14px; color: #666; margin-top: 4px; }

    /* Meta grid */
    .meta { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 36px; padding-bottom: 36px; border-bottom: 2px solid #f0f0f0; }
    .meta-block label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #9ca3af; font-weight: 600; display: block; margin-bottom: 4px; }
    .meta-block p { font-size: 13px; color: #111; line-height: 1.5; }
    .meta-block strong { font-weight: 600; }

    /* Addresses */
    .addresses { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 36px; }
    .address-block h3 { font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #9ca3af; font-weight: 600; margin-bottom: 8px; }
    .address-block p { line-height: 1.7; color: #374151; }
    .address-block .name { font-weight: 600; font-size: 14px; color: #111; margin-bottom: 2px; }

    /* Payment summary */
    .payment-summary { margin-bottom: 36px; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; }
    .payment-summary-header { background: {{brandPrimary}}; color: #fff; padding: 10px 16px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .payment-summary-body { padding: 0; }
    .payment-row { display: flex; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid #f0f0f0; }
    .payment-row:last-child { border-bottom: none; }
    .payment-row .label { color: #6b7280; font-size: 13px; }
    .payment-row .value { font-weight: 500; font-size: 13px; color: #111; }
    .payment-row.total { background: #f9fafb; }
    .payment-row.total .label { font-weight: 600; font-size: 15px; color: #111; }
    .payment-row.total .value { font-weight: 700; font-size: 15px; color: {{brandPrimary}}; }

    /* Invoice reference */
    .invoice-ref { margin-bottom: 36px; padding: 12px 16px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; font-size: 13px; color: #1e40af; }
    .invoice-ref strong { font-weight: 600; }

    /* Notes */
    .footer-section { margin-top: 40px; border-top: 2px solid #f0f0f0; padding-top: 28px; }
    .footer-section h4 { font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: #9ca3af; font-weight: 600; margin-bottom: 8px; }
    .footer-section p { font-size: 12px; color: #4b5563; line-height: 1.7; }

    /* Thank you */
    .thank-you { text-align: center; margin-top: 40px; font-size: 13px; color: #9ca3af; }
  </style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="header">
    <div>
      {{#if org.logo}}
        <img class="logo" src="{{org.logo}}" alt="{{org.name}}" />
      {{else}}
        <div class="org-name">{{org.name}}</div>
      {{/if}}
      <div style="margin-top: 6px; font-size: 12px; color: #6b7280; line-height: 1.6;">
        {{org.address.line1}}{{#if org.address.line2}}, {{org.address.line2}}{{/if}}<br/>
        {{org.address.city}}, {{org.address.state}} {{org.address.postalCode}}<br/>
        {{#if org.taxId}}GSTIN: {{org.taxId}}{{/if}}
      </div>
    </div>
    <div class="doc-title">
      <h1>PAYMENT RECEIPT</h1>
      <div class="doc-number">{{payment.paymentNumber}}</div>
    </div>
  </div>

  <!-- Meta -->
  <div class="meta">
    <div class="meta-block">
      <label>Payment Date</label>
      <p><strong>{{formatDate payment.paymentDate}}</strong></p>
    </div>
    <div class="meta-block">
      <label>Currency</label>
      <p>{{payment.currency}}</p>
    </div>
  </div>

  <!-- Addresses -->
  <div class="addresses">
    <div class="address-block">
      <h3>Received By</h3>
      <div class="name">{{org.name}}</div>
      <p>{{org.address.line1}}{{#if org.address.line2}}<br/>{{org.address.line2}}{{/if}}<br/>
      {{org.address.city}}, {{org.address.state}} {{org.address.postalCode}}<br/>
      {{org.address.country}}<br/>
      {{#if org.email}}{{org.email}}{{/if}}</p>
    </div>
    <div class="address-block">
      <h3>Received From</h3>
      <div class="name">{{client.displayName}}</div>
      {{#if client.billingAddress}}
      <p>{{client.billingAddress.line1}}{{#if client.billingAddress.line2}}<br/>{{client.billingAddress.line2}}{{/if}}<br/>
      {{client.billingAddress.city}}, {{client.billingAddress.state}} {{client.billingAddress.postalCode}}<br/>
      {{client.billingAddress.country}}</p>
      {{/if}}
      {{#if client.email}}<p>{{client.email}}</p>{{/if}}
    </div>
  </div>

  <!-- Payment Summary -->
  <div class="payment-summary">
    <div class="payment-summary-header">Payment Details</div>
    <div class="payment-summary-body">
      <div class="payment-row">
        <span class="label">Payment Method</span>
        <span class="value">{{payment.method}}</span>
      </div>
      {{#if payment.referenceNumber}}
      <div class="payment-row">
        <span class="label">Reference Number</span>
        <span class="value">{{payment.referenceNumber}}</span>
      </div>
      {{/if}}
      {{#if payment.gateway}}
      <div class="payment-row">
        <span class="label">Payment Gateway</span>
        <span class="value">{{payment.gateway}}</span>
      </div>
      {{/if}}
      <div class="payment-row total">
        <span class="label">Amount Paid</span>
        <span class="value">{{formatMoney payment.amount payment.currency}}</span>
      </div>
    </div>
  </div>

  <!-- Invoice Reference -->
  {{#if invoice}}
  <div class="invoice-ref">
    <strong>Payment for Invoice:</strong> {{invoice.invoiceNumber}}
    {{#if invoice.total}} — Invoice Total: {{formatMoney invoice.total invoice.currency}}{{/if}}
  </div>
  {{/if}}

  <!-- Notes -->
  {{#if payment.notes}}
  <div class="footer-section">
    <div>
      <h4>Notes</h4>
      <p>{{payment.notes}}</p>
    </div>
  </div>
  {{/if}}

  <div class="thank-you">Thank you for your payment!</div>
</div>
</body>
</html>
