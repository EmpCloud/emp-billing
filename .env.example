NODE_ENV=development
PORT=4001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5174

# ── Database ──────────────────────────────────────────
# DB_PROVIDER: "mysql" | "pg"
DB_PROVIDER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=emp_billing_secret
DB_NAME=emp_billing
DB_POOL_MIN=2
DB_POOL_MAX=10

MONGO_URI=mongodb://localhost:27017/emp_billing

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email ─────────────────────────────────────────────
# EMAIL_PROVIDER: "smtp" (default) | "sendgrid" | "ses"
# - smtp:     Uses SMTP_* vars below (works with any SMTP relay)
# - sendgrid: Uses SendGrid SMTP relay. Set SENDGRID_API_KEY below.
# - ses:      Uses AWS SES via SDK. Set AWS_SES_* vars below.
EMAIL_PROVIDER=smtp

# SMTP settings (used when EMAIL_PROVIDER=smtp, or as fallback)
# For dev: use Mailpit (docker compose --profile dev up)
# Mailpit UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=billing@empcloud.com
SMTP_FROM_NAME=EMP Billing

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
# Sign up at https://sendgrid.com — create an API key with Mail Send permission
SENDGRID_API_KEY=

# AWS SES (used when EMAIL_PROVIDER=ses)
# Ensure the SMTP_FROM address is verified in SES
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=

# ── File uploads ──────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ── Security ──────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Payment Gateways ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: override Stripe Checkout redirect URLs (defaults to portal URLs derived from CORS_ORIGIN)
# STRIPE_SUCCESS_URL=https://yourdomain.com/portal/invoices?payment=success
# STRIPE_CANCEL_URL=https://yourdomain.com/portal/invoices?payment=cancelled
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true

# ── Exchange Rates ────────────────────────────────────
EXCHANGE_RATE_API_KEY=
